# WSAPI Configuration
WSAPI_API_KEY=your_api_key_here
WSAPI_INSTANCE_ID=your_instance_id_here
WSAPI_BASE_URL=https://api.wsapi.chat

# Server configuration
PORT=3000
LOG_LEVEL=info

# Tool filtering (optional)
# WSAPI_ENABLED_CATEGORIES=messaging,contacts,session
# WSAPI_ENABLED_TOOLS=whatsapp_send_text,whatsapp_get_chats

# Development
NODE_ENV=development
